{
  "entry": ["src/**/index.ts"],
  "ignoreBinaries": [
    "plantuml",
    "tsx",
    "rimraf",
    "cross-env",
    "rollup",
    "auto-changelog",
    "typedoc",
    "knip",
    "eslint",
    "dotenvx",
    "release-it",
    "vitest",
    "tsc"
  ],
  "ignoreDependencies": [
    "@langchain/qdrant",
    "json5",
    "tiktoken",
    "commander",
    "@dotenvx/dotenvx",
    "auto-changelog",
    "cross-env",
    "happy-dom",
    "release-it",
    "tslib",
    "typedoc"
  ],
  "project": ["*/**", "!docs/**"],
  "rules": {
    "exports": "off",
    "types": "off"
  },
  "vitest": {
    "entry": ["*/**/*.test.!(*.*)"]
  }
}
