{
  "entryPoints": [
    "./packages/service/src/index.ts"
  ],
  "highlightLanguages": [
    "bash",
    "console",
    "css",
    "html",
    "javascript",
    "json",
    "jsonc",
    "json5",
    "md",
    "tsx",
    "typescript",
    "yaml",
    "yml",
    "mermaid",
    "powershell",
    "ini",
    "nginx",
    "handlebars"
  ],
  "hostedBaseUrl": "https://docs.karmanivero.us/jeeves-watcher",
  "navigationLinks": {
    "GitHub": "https://github.com/karmaniverous/jeeves-watcher"
  },
  "out": "./docs/",
  "plugin": [
    "typedoc-plugin-mdn-links",
    "typedoc-plugin-replace-text"
  ],
  "projectDocuments": [
    "./packages/service/guides/index.md",
    "./packages/openclaw/guides/index.md"
  ],
  "replaceText": {
    "replacements": [
      {
        "pattern": "<!-- TYPEDOC_EXCLUDE -->.*?<!-- /TYPEDOC_EXCLUDE -->",
        "flags": "gis",
        "replace": ""
      }
    ]
  },
  "searchInComments": true,
  "searchInDocuments": true,
  "validation": {
    "notDocumented": false
  }
}
